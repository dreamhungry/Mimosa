# Mimosa Configuration
# Copy this file to conf.yaml and fill in your values:
#   cp conf.yaml.example conf.yaml

server:
  host: "0.0.0.0"
  port: 8000

character:
  name: "Mimosa"
  persona_prompt_path: "prompts/persona_mimosa.txt"
  live2d_model_name: "mao_pro"

llm:
  provider: "openai_compatible"
  model: "gpt-4o-mini"
  base_url: "https://api.openai.com/v1"
  api_key: "your-api-key-here"
  temperature: 0.7
  max_tokens: 1024

asr:
  # Option 1: FunASR (recommended, better accuracy)
  engine: "funasr"
  model: "paraformer-zh"          # Model name from ModelScope
  device: "cuda:0"                # "cuda:0" for GPU, "cpu" for CPU
  vad_model: "fsmn-vad"           # Built-in VAD for segmentation
  punc_model: "ct-punc"           # Punctuation restoration
  sample_rate: 16000
  cache_dir: "D:/cache"           # Model cache directory (empty = system default)

  # Option 2: Sherpa ONNX (lightweight, CPU-only, lower accuracy)
  # engine: "sherpa_onnx"
  # model_path: "models/sherpa-onnx-zipformer-zh-en-2023-11-22"
  # sample_rate: 16000

tts:
  engine: "edge_tts"
  voice: "zh-CN-XiaoxiaoNeural"
  rate: "+0%"
  volume: "+0%"

vad:
  engine: "silero"
  threshold: 0.5
  min_silence_duration_ms: 500
  speech_pad_ms: 300
